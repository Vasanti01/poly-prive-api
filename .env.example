# Moralis Web3 Data API key — https://admin.moralis.io/
MORALIS_API_KEY=your_moralis_api_key_here

# Default EVM chain: eth, polygon, bsc, arbitrum, base, optimism, etc.
DEFAULT_CHAIN=eth

# Server (Railway injects PORT automatically — do not hardcode in production)
PORT=3000
NODE_ENV=production

# Comma-separated allowed origins for CORS (use * for development only)
CORS_ORIGIN=*
